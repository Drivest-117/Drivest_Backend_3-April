{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "es2017",
    "moduleResolution": "node",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "types": ["node"],
    "strict": true,
    "strictPropertyInitialization": false,
    "paths": {
      "*": ["src/*"]
    }
    
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
